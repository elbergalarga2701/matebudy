# =============================================================================
# MATEBUDY - Variables de Entorno para Desarrollo Local
# =============================================================================
# Este archivo es para desarrollo local. No lo subas al repositorio.
# Para producción, usa .env.production o variables de entorno del servidor.
# =============================================================================

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
JWT_SECRET=dev_secret_change_in_production_123456789
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_987654321

# -----------------------------------------------------------------------------
# CONFIGURACION DEL SERVIDOR
# -----------------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
JSON_LIMIT=10mb
ADMIN_PANEL_CODE=dev1234

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# BASE DE DATOS
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite://./matebudy.sqlite

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_UPDATE_URL=http://localhost:3000/update.json

# -----------------------------------------------------------------------------
# TOKENS
# -----------------------------------------------------------------------------
JWT_ACCESS_TTL=7d
JWT_REFRESH_TTL=30d
JWT_ACCESS_MAX_AGE_MS=604800000
JWT_REFRESH_MAX_AGE_MS=2592000000

# -----------------------------------------------------------------------------
# REGISTRO
# -----------------------------------------------------------------------------
REGISTRATION_RETRY_ATTEMPTS=5
REGISTRATION_RETRY_DELAY_MS=150

# -----------------------------------------------------------------------------
# COOKIES
# -----------------------------------------------------------------------------
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# PAGOS (Mercado Pago - Sandbox)
# -----------------------------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=
PLATFORM_COMMISSION_RATE=0.15

# -----------------------------------------------------------------------------
# FIREBASE (Opcional)
# -----------------------------------------------------------------------------
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# MAPAS (Opcional)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# ARCHIVOS
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=8388608
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# -----------------------------------------------------------------------------
# RATE LIMITING (más permisivo en desarrollo)
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_LOGIN_MAX=50
RATE_LIMIT_REGISTER_MAX=100

# -----------------------------------------------------------------------------
# BACKUPS
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_DIR=./backups

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FILE=./logs/server.log

# -----------------------------------------------------------------------------
# ACTUALIZACION
# -----------------------------------------------------------------------------
APP_VERSION=1.0.0
APP_NATIVE_UPDATE_REQUIRED=false
