NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Frontend / mobile origins allowed to call the API.
# Separate multiple values with commas.
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://api.tu-dominio.com

# Security
JWT_SECRET=cambia-esto-por-un-secreto-largo
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-largo
ADMIN_PANEL_CODE=cambia-esto-por-un-codigo-admin-seguro

# Optional runtime tuning
JSON_LIMIT=10mb
UPLOADS_DIR=../uploads

# Public app / payment URLs
APP_BASE_URL=https://tu-dominio.com
MP_ENVIRONMENT=test
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=https://tu-dominio.com/api/payments/webhook
MP_SUCCESS_URL=https://tu-dominio.com/chat?payment=success
MP_PENDING_URL=https://tu-dominio.com/chat?payment=pending
MP_FAILURE_URL=https://tu-dominio.com/chat?payment=failure
